{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "compile and run (C++17 with I/O)",
      "type": "shell",
      "command": "bash",
      "args": [
        "-c",
        "g++ -std=c++17 -g \"${file}\" -o \"${fileDirname}/${fileBasenameNoExtension}.out\" && /usr/bin/time -lp \"${fileDirname}/${fileBasenameNoExtension}.out\" < input.txt > output.txt && rm -f \"${fileDirname}/${fileBasenameNoExtension}.out\" && rm -rf \"${fileDirname}/${fileBasenameNoExtension}.out.dSYM\""
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": []
    },
    {
      "label": "compile and run (C++17 only)",
      "type": "shell",
      "command": "bash",
      "args": [
        "-c",
        "g++ -std=c++17 -g \"${file}\" -o \"${fileDirname}/${fileBasenameNoExtension}.out\" && /usr/bin/time -lp \"${fileDirname}/${fileBasenameNoExtension}.out\""
      ],
      "group": "build",
      "problemMatcher": []
    },
